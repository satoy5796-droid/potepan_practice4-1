<h1>予定一覧</h1>

<!-- ヘッダーと一覧の間に配置 -->
<div class="new-schedule-btn-container">
  <%= link_to "新規予定を登録する", new_schedule_path, class: "btn-new" %>
</div>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>タイトル</th>
      <th>開始日</th>
      <th>終了日</th>
      <th>終日</th>
      <th>更新日時</th>
      <th></th>
    </tr>
  </thead>
  <tbody>
    <% @schedules.each do |schedule| %>
      <tr>
        <td><%= schedule.id %></td>
        <td><%= schedule.title %></td>
        <td><%= schedule.start_date.strftime("%Y/%m/%d") %></td>
        <td><%= schedule.end_date.strftime("%Y/%m/%d") %></td>
        <td><%= "○" if schedule.all_day %></td>
        <td><%= schedule.updated_at.strftime("%Y/%m/%d %H:%M") %></td>
        <td>
          <%= link_to "詳細", schedule %>
          <%= link_to "編集", edit_schedule_path(schedule) %>
          <%= link_to "削除", schedule, data: { turbo_method: :delete, turbo_confirm: "予定を削除しますか？" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<div class="info-section">
  <p>予定合計: <strong><%= @schedules.count %></strong> 件</p>
  <p>本日の日付: <%= Time.current.strftime("%Y/%m/%d") %></p>
</div>

